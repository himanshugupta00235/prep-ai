rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Default: Deny all access ──────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Users Collection ──────────────────────────────────
    // Users can only read and write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ─── Questions Collection ──────────────────────────────
    // All authenticated users can read questions.
    // Only admins can write (seeded via script or console).
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if false; // Managed via seed script or Firebase Console
    }

    // ─── Bookmarks Collection ──────────────────────────────
    // Users can only manage their own bookmarks.
    match /bookmarks/{bookmarkId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow update: if false; // Bookmarks are immutable
    }
  }
}
